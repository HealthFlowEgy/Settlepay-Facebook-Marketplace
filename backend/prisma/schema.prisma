// SettePay Marketplace — Prisma Schema
// ME-06 fix: MerchantToken model REMOVED — merchant JWT now stored in Redis only (CR-06)
// New: isAdmin field added to User for AdminController role guard

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserKycTier {
  TIER_0  // Phone only — EGP 200/tx, 500/day, 2000/month
  TIER_1  // Phone + National ID — EGP 1,000/day
  TIER_2  // ID + selfie + address — EGP 10,000/day
  TIER_3  // Full enhanced KYC — EGP 50,000/day
}

enum UserKycStatus {
  PENDING
  APPROVED
  REJECTED
  UNDER_REVIEW
}

enum DealStatus {
  PENDING
  AWAITING_BUYER_CONFIRMATION
  AWAITING_TOP_UP
  ESCROW_DEDUCTING
  ESCROW_ACTIVE
  SHIPPED
  DELIVERY_CONFIRMED
  SETTLING
  SETTLED
  DISPUTED
  REFUNDING
  REFUNDED
  PAYOUT_FAILED
  PAYMENT_ERROR
  CANCELLED
}

enum DisputeStatus {
  OPEN
  EVIDENCE_COLLECTION
  UNDER_REVIEW
  RESOLVED
}

enum DisputeResolution {
  FULL_RELEASE
  PARTIAL
  FULL_REFUND
}

enum NotificationChannel {
  MESSENGER
  SMS
  PUSH
  EMAIL
}

enum NotificationStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

// ─── MODELS ───────────────────────────────────────────────────────────────────

model User {
  id               String        @id @default(uuid())
  mobile           String        @unique
  firstName        String
  lastName         String
  email            String?       @unique
  passwordHash     String?
  isProvider       Boolean       @default(false)
  isAdmin          Boolean       @default(false)  // AdminController role guard

  // HealthPay integration
  hpUserToken      String?       // AES-256 encrypted HealthPay userToken
  hpUid            String?       @unique
  hpTokenUpdatedAt DateTime?

  // KYC
  kycTier          UserKycTier   @default(TIER_0)
  kycStatus        UserKycStatus @default(PENDING)
  nationalId       String?       // AES-256 encrypted
  kycVerifiedAt    DateTime?
  kycProvider      String?       @default("valify")

  // AML tracking
  monthlyVolume    Decimal       @default(0) @db.Decimal(12, 2)
  monthlyVolumeResetAt DateTime  @default(now())
  isBlocked        Boolean       @default(false)
  blockReason      String?

  // Facebook / OAuth (HI-09)
  facebookId       String?       @unique
  facebookName     String?

  // Messenger Bot (GAP-01 / A.2)
  psid             String?       @unique
  messengerLinked  Boolean       @default(false)
  messengerLinkedAt DateTime?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  dealsAsBuyer     Deal[]        @relation("BuyerDeals")
  dealsAsSeller    Deal[]        @relation("SellerDeals")
  disputesRaised   Dispute[]     @relation("DisputeRaisedBy")
  notifications    NotificationEvent[]
  auditLogs        AuditLog[]

  @@index([mobile])
  @@index([hpUid])
  @@index([facebookId])
  @@index([psid])
}

model Deal {
  id               String      @id @default(uuid())
  buyerId          String
  sellerId         String
  // GAP-FIX-05: Decimal avoids floating-point rounding errors for financial amounts
  amount           Decimal     @db.Decimal(12, 2)
  commission       Decimal?    @db.Decimal(12, 2)
  netPayout        Decimal?    @db.Decimal(12, 2)

  status           DealStatus  @default(PENDING)

  itemDescription  String
  itemCategory     String?

  // Messenger context
  messengerThreadId String?
  botMessageId      String?

  // Logistics
  waybillId        String?
  logisticsProvider String?   @default("bosta")
  shippedAt        DateTime?
  deliveredAt      DateTime?

  // Timeline
  escrowActivatedAt  DateTime?
  buyerConfirmedAt   DateTime?
  buyerConfirmDeadline DateTime?
  disputeWindowEnd   DateTime?
  escrowExpiresAt    DateTime?

  // Idempotency
  deductIdempotencyKey String? @unique
  payoutIdempotencyKey String? @unique

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  settledAt        DateTime?
  cancelledAt      DateTime?
  cancelReason     String?

  // Relations
  buyer            User        @relation("BuyerDeals",  fields: [buyerId],  references: [id])
  seller           User        @relation("SellerDeals", fields: [sellerId], references: [id])
  escrowTx         EscrowTransaction?
  dispute          Dispute?
  commissionRecord CommissionRecord?
  notifications    NotificationEvent[]
  auditLogs        AuditLog[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([waybillId])
}

model EscrowTransaction {
  id              String    @id @default(uuid())
  dealId          String    @unique

  hpDeductionRef  String?
  hpPayoutRef     String?
  hpPaymentReqId  String?

  amount          Decimal   @db.Decimal(12, 2)
  commissionAmount Decimal? @db.Decimal(12, 2)
  netPayout       Decimal?  @db.Decimal(12, 2)

  deductedAt      DateTime?
  deductSuccess   Boolean?
  paidOutAt       DateTime?
  payoutSuccess   Boolean?
  payoutAttempts  Int       @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  deal            Deal      @relation(fields: [dealId], references: [id])

  @@index([dealId])
  @@index([hpDeductionRef])
}

model Dispute {
  id              String          @id @default(uuid())
  dealId          String          @unique
  raisedById      String

  status          DisputeStatus   @default(OPEN)
  resolution      DisputeResolution?

  sellerPayout    Decimal?        @db.Decimal(12, 2)
  buyerRefund     Decimal?        @db.Decimal(12, 2)

  buyerEvidence   String[]
  sellerEvidence  String[]
  adminNotes      String?

  evidenceDeadline   DateTime?
  resolutionDeadline DateTime?
  resolvedAt         DateTime?
  resolvedById       String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  deal            Deal            @relation(fields: [dealId], references: [id])
  raisedBy        User            @relation("DisputeRaisedBy", fields: [raisedById], references: [id])

  @@index([dealId])
  @@index([status])
}

model CommissionRecord {
  id               String    @id @default(uuid())
  dealId           String    @unique

  grossAmount      Decimal   @db.Decimal(12, 2)
  commissionRate   Decimal   @db.Decimal(6, 4)
  commissionAmount Decimal   @db.Decimal(12, 2)
  netPayout        Decimal   @db.Decimal(12, 2)
  hpPayoutRef      String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt   // GAP-FIX-05: Track last modification for audit

  deal             Deal      @relation(fields: [dealId], references: [id])

  @@index([dealId])
  @@index([createdAt])
}

model AuditLog {
  id              String    @id @default(uuid())
  userId          String?
  dealId          String?

  operation       String
  hpOperation     String?
  requestSummary  Json?
  responseCode    String?
  responseSuccess Boolean?
  outcome         String?
  errorMessage    String?
  ipAddress       String?
  userAgent       String?

  createdAt       DateTime  @default(now())

  user            User?     @relation(fields: [userId], references: [id])
  deal            Deal?     @relation(fields: [dealId], references: [id])

  @@index([userId])
  @@index([dealId])
  @@index([operation])
  @@index([createdAt])
}

model NotificationEvent {
  id          String              @id @default(uuid())
  userId      String
  dealId      String?

  channel     NotificationChannel
  type        String
  status      NotificationStatus  @default(QUEUED)
  payload     Json?
  externalId  String?
  error       String?
  sentAt      DateTime?
  deliveredAt DateTime?

  createdAt   DateTime            @default(now())

  user        User                @relation(fields: [userId], references: [id])
  deal        Deal?               @relation(fields: [dealId], references: [id])

  @@index([userId])
  @@index([dealId])
  @@index([status])
}

// Messenger Bot session (GAP-01 / A.2)
model BotSession {
  id        String   @id @default(cuid())
  psid      String   @unique
  state     String   @default("IDLE")
  context   Json?
  dealId    String?
  userId    String?
  updatedAt DateTime @updatedAt

  @@index([psid])
}

// ME-06: MerchantToken model REMOVED.
// Merchant JWT is stored exclusively in Redis (hp:merchant:token key, 23h TTL).
// Migration: DROP TABLE IF EXISTS "MerchantToken";

model OtpThrottle {
  mobile        String    @id
  attempts      Int       @default(0)
  blockedUntil  DateTime?
  lastAttemptAt DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
